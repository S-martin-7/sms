# Copy to .env and fill in real values. Never commit .env.
# Load locally with:  set -a && source .env && set +a

# Postgres DSN for the sms gateway.
# On the VPS, Postgres listens on 127.0.0.1:5432 only.
DATABASE_URL=postgres://sms:REPLACE_ME@localhost:5432/sms?sslmode=disable
DATABASE_URL_TEST=postgres://sms:REPLACE_ME@localhost:5432/sms_test?sslmode=disable

# HTTP listen address for the sms-server binary.
HTTP_LISTEN=:7300

# Secrets (generated with `openssl rand -hex 32`). Leave as placeholders for now;
# they get populated in later plan tasks (auth, webhooks).
JWT_SECRET=REPLACE_ME
HMAC_PEPPER=REPLACE_ME
API_KEY_PEPPER=REPLACE_ME

# Horisen SMS provider (from the credentials workbook).
# HORISEN_BASE_URL is the origin ONLY — the client appends /bulk/sendsms.
HORISEN_BASE_URL=https://194.0.137.123:42108
HORISEN_USERNAME=16602_SamuelOTP
HORISEN_PASSWORD=REPLACE_ME
HORISEN_TPS=10
HORISEN_VALIDITY_SEC=86400
# Override TLS validation hostname when connecting via IP. The Horisen
# endpoint uses a *.horisen.pro wildcard cert, so set this to any
# <something>.horisen.pro to validate against that CN.
HORISEN_TLS_SERVER_NAME=sms.horisen.pro
# Shared secret for the DLR/MO callback URLs we give to Horisen
# (included as ?sig=... query param).
HORISEN_CALLBACK_SECRET=REPLACE_ME

# Public base URL our sms-server serves on (used to build the DLR callback URL
# Horisen will post to). Example: https://sms.aipanel.cl
PUBLIC_BASE_URL=REPLACE_ME
