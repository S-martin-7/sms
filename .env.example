# Copy to .env and fill in real values. Never commit .env.
# Load locally with:  set -a && source .env && set +a

# Postgres DSN for the sms gateway.
# On the VPS, Postgres listens on 127.0.0.1:5432 only.
DATABASE_URL=postgres://sms:REPLACE_ME@localhost:5432/sms?sslmode=disable
DATABASE_URL_TEST=postgres://sms:REPLACE_ME@localhost:5432/sms_test?sslmode=disable

# HTTP listen address for the sms-server binary.
HTTP_LISTEN=:7300

# Secrets (generated with `openssl rand -hex 32`). Leave as placeholders for now;
# they get populated in later plan tasks (auth, webhooks).
JWT_SECRET=REPLACE_ME
HMAC_PEPPER=REPLACE_ME
API_KEY_PEPPER=REPLACE_ME
