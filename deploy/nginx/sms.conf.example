# Reverse-proxy vhost for the sms gateway.
# Copy to /etc/nginx/sites-available/sms, `sed -i s/__DOMAIN__/sms.example.com/g`,
# then `ln -s` into sites-enabled and reload nginx.
# Requires a Let's Encrypt cert:  certbot --nginx -d __DOMAIN__

# Tenant-facing API rate limit (token bucket on the edge).
# 20 req/s burst 40 per IP — per-tenant quotas are enforced inside the app.
limit_req_zone $binary_remote_addr zone=sms_api:10m rate=20r/s;

server {
    listen 80;
    listen [::]:80;
    server_name __DOMAIN__;

    # HTTP → HTTPS redirect (certbot injects its own ACME block above this).
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name __DOMAIN__;

    ssl_certificate     /etc/letsencrypt/live/__DOMAIN__/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/__DOMAIN__/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options nosniff always;

    client_max_body_size 2m;

    # Tenant-facing API
    location /v1/ {
        limit_req zone=sms_api burst=40 nodelay;
        proxy_pass http://127.0.0.1:7300;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_read_timeout 30s;
    }

    # Admin dashboard + login
    location /admin/ {
        proxy_pass http://127.0.0.1:7300;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }

    # Dashboard static assets (future: Vite build output)
    # location /dashboard/ {
    #     alias /root/sms/dashboard/dist/;
    #     try_files $uri $uri/ /dashboard/index.html;
    # }

    location = / {
        return 404;
    }
}
